# Sadaqah Sweden — miljövariabler
# Kopiera denna fil till .env.local och fyll i värdena.
# .env.local committas ALDRIG till git (ligger i .gitignore).
#
# OBS: landningssidan kräver INGA av dessa för att köras.
# De behövs först när databas- och betalfunktioner byggs.

# --- Supabase (Steg 1 och framåt) ---
# Hämtas i Supabase-dashboarden → Project Settings → API
# Projekt: dcfrvomfztgkbfoegwge (eu-north-1)
NEXT_PUBLIC_SUPABASE_URL=https://dcfrvomfztgkbfoegwge.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=  # 'anon' public key — säker att exponera
SUPABASE_SERVICE_ROLE_KEY=      # SERVERSIDE BARA — aldrig i klienten

# --- Webbplatsens adress ---
NEXT_PUBLIC_SITE_URL=https://sadaqahsweden.se

# --- Stripe (Steg 5 och framåt — börja i testläge) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- E-post, Resend (Steg 6 och framåt) ---
RESEND_API_KEY=

# --- BankID-broker (parallellt spår) ---
# Fylls i när broker-avtal finns — se ../2-Byggplan/03-BankID-auth-donationsflode.md
BANKID_BROKER_CLIENT_ID=
BANKID_BROKER_CLIENT_SECRET=
BANKID_BROKER_DOMAIN=

# --- Skolan (Kunskap-rummet) — feature-flaggor (56b §6) ---
# Default AV för allt som hänger på en obyggd modul. Läs server-side.
SKOLA_AKTIV=true                  # Hela skol-ytan synlig i Kunskap-rummet (default på)
SKOLA_GEMENSAMT_BIBLIOTEK=false   # Gemensamt verifierat bibliotek (kräver #34)
SKOLA_KORAN_DATA=false            # Riktig Koran-text/uttal (kräver #6/#7)
SKOLA_KORAN_DEMO=true             # Seedad demo-ayah för skriv-canvasen (default på i dev)
SKOLA_STRIPE_AKTIV=false          # Riktig premium-betalning (kräver #12 + Stripe-produkter)
NEXT_PUBLIC_DOCSERVER_URL=        # OnlyOffice doc-server (tom = dokument-editor stubbad)
